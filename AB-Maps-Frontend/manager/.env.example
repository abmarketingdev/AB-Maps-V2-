# ── AB Maps Manager app (Create React App) — environment ──
# Copy to .env and fill in. All REACT_APP_* vars are inlined at build time.

# Backend API + base URLs
REACT_APP_API_URL=http://localhost:8000
REACT_APP_BACKEND_URL=http://localhost:8000

# This app's own public URL + where to send users to log in
REACT_APP_FRONTEND_URL=http://localhost:3001
REACT_APP_LOGIN_URL=http://localhost:3000/login

# Vector tile server (MVT) for area tiles
REACT_APP_TILE_SERVER_URL=http://localhost:8000/tiles
REACT_APP_ENABLE_VECTOR_TILES=true

# Optional rendering flags
NEXT_PUBLIC_DISABLE_ROTATION_ON_MOBILE=false
NEXT_PUBLIC_SAFE_RENDER_MODE=false

# Subpath the app is served under (CRA). Leave empty for root.
PUBLIC_URL=
