# ── AB Maps Employee app — environment ──
# Copy to .env and fill in. REACT_APP_* vars are inlined at build time.

# Backend API + base URLs
REACT_APP_API_BASE_URL=http://localhost:8000
REACT_APP_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Where to send users to log in
REACT_APP_LOGIN_URL=http://localhost:3000/login

# Vector tile server (MVT) for area tiles
# NOTE: bare origin — the app appends /tiles/{z}/{x}/{y}.pbf itself (do NOT add /tiles here)
REACT_APP_TILE_SERVER_URL=http://localhost:8000

# Optional rendering flags
NEXT_PUBLIC_DISABLE_ROTATION_ON_MOBILE=false
NEXT_PUBLIC_SAFE_RENDER_MODE=false
