# ── AB Maps Dashboard (Next.js) — environment ──
# Copy to .env.local and fill in for your environment.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Server-side backend URL (used by Next route handlers / proxies). Usually same as above.
BACKEND_URL=http://localhost:8000

# Links to the companion apps (used by the "open in app" buttons)
NEXT_PUBLIC_AB_MAPS_MANAGER_URL=http://localhost:3001
NEXT_PUBLIC_AB_MAPS_EMPLOYEE_URL=http://localhost:3002

# MapLibre style URL (vector tiles base map)
NEXT_PUBLIC_MAP_STYLE=https://your-map-style-url/style.json

# DEV ONLY — anchors the Analytics date window to a date that overlaps seeded
# door-knock data (which ends 2026-03-19 in the dev DB). Leave UNSET in production
# so the dashboard uses the real current date.
# NEXT_PUBLIC_ANALYTICS_ANCHOR_DATE=2026-03-19
