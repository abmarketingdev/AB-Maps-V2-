# Django Settings
# Generate a fresh secret, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=false
DJANGO_SETTINGS_MODULE=ab_maps.settings_production

# Database Settings (PostgreSQL / PostGIS)
POSTGRES_DB=ab_maps_db
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Settings
REDIS_URL=redis://localhost:6379

# CORS Settings (comma-separated frontend origins)
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,http://localhost:3000

# Public host (e.g. Render external hostname) — used for ALLOWED_HOSTS
RENDER_EXTERNAL_HOSTNAME=your-service-name.onrender.com

# Frontend base URL used to build password-reset links in emails
FRONTEND_URL=https://your-frontend-domain.com

# SMTP (for password-reset + report emails); see PRODUCTION_EMAIL_SETUP.md
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_smtp_user
EMAIL_HOST_PASSWORD=your_smtp_password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=AB Maps <no-reply@your-domain.com>
